# Required: Anthropic API key for the control loop (Sonnet) + extraction (Haiku) + judge (Opus)
ANTHROPIC_API_KEY=sk-ant-...

# Optional but recommended: Apify token unlocks the apify_scrape tool (structured extraction).
# Without it the agent still runs and gracefully degrades to web_search/web_fetch.
APIFY_TOKEN=apify_api_...

# Optional: Tavily key makes web_search faster/more reliable.
# Without it, web_search falls back to DuckDuckGo (free, no key, but more rate-limited).
TAVILY_API_KEY=tvly-...

# Eval judge panel (EVAL ONLY — the agent never uses these). The eval scores answers
# with a cross-provider panel so Claude isn't the only model grading Claude. Whichever
# of these are present join the panel; missing ones are skipped.
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...
